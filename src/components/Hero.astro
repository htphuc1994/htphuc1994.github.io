---
import { profile } from "../data/cv";
---

<section class="hero" id="top">
  <div class="container grid">
    <div>
      <div class="eyebrow">Available for senior &amp; staff engineering roles</div>
      <h1>
        {profile.name.split(" (")[0]} <span class="accent">(Levi)</span><br />
        Huynh
      </h1>
      <p class="tagline">
        Senior Software Engineer with 10+ years building scalable platforms across
        fintech, healthcare, and edtech. Currently at <a href="https://www.propelventures.com.au/">Propel Ventures</a>, working on Tinybeans &amp; Education Perfect.
      </p>
      <div class="cta-row">
        <a class="btn primary" href={profile.resumePdf} download>
          <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3" />
          </svg>
          Download CV (PDF)
        </a>
        <a class="btn" href={`mailto:${profile.email}`}>
          <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="5" width="18" height="14" rx="2" /><path d="m3 7 9 6 9-6" />
          </svg>
          Get in touch
        </a>
        <a class="btn" href={profile.github} target="_blank" rel="noopener">
          <svg class="icon" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2.16c-3.2.7-3.87-1.37-3.87-1.37-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.68 1.24 3.34.95.1-.74.4-1.24.73-1.52-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.04 0 0 .97-.31 3.18 1.18a11.1 11.1 0 0 1 5.79 0c2.21-1.49 3.18-1.18 3.18-1.18.63 1.58.23 2.75.11 3.04.73.81 1.18 1.84 1.18 3.1 0 4.42-2.69 5.39-5.25 5.68.41.35.78 1.04.78 2.1v3.11c0 .31.21.66.8.55C20.21 21.38 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5Z" />
          </svg>
          GitHub
        </a>
        <a class="btn" href={profile.linkedin} target="_blank" rel="noopener">
          <svg class="icon" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.45 20.45h-3.55v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.95v5.66H9.36V9h3.41v1.56h.05c.47-.9 1.63-1.85 3.36-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45z" />
          </svg>
          LinkedIn
        </a>
      </div>
    </div>
    <img class="photo" src={profile.photo} alt={`Portrait of ${profile.name}`} width="200" height="240" />
  </div>
</section>
